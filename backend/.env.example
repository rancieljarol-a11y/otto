# OttO Environment Variables
# Copy this to .env and fill in your values

# Server
PORT=3001
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=otto
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# WhatsApp - 360dialog
WHATSAPP_API_URL=https://wapi.360dialog.com
WHATSAPP_API_KEY=your_360dialog_api_key
WHATSAPP_WEBHOOK_TOKEN=otto-webhook-verify-token

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key

# Clerk (Auth)
CLERK_SECRET_KEY=sk_your_clerk_secret
CLERK_PUBLISHABLE_KEY=pk_your_clerk_publishable

# Resend (Email)
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=noreply@otto.app

# PostHog (Analytics)
POSTHOG_API_KEY=your_posthog_api_key
POSTHOG_HOST=https://app.posthog.com

# Local AI (Nivel 3)
LOCAL_AI_ENABLED=false
LOCAL_AI_URL=http://localhost:11434/api/generate
LOCAL_AI_MODEL=mistral

# Cloud AI (Nivel 4 fallback)
CLOUD_AI_PROVIDER=anthropic
CLOUD_AI_API_KEY=sk-ant-your-anthropic-key
CLOUD_AI_MODEL=claude-3-sonnet-20240229

# Whisper (voice to text)
WHISPER_ENABLED=false
WHISPER_MODEL_PATH=./models/whisper

# Tesseract (OCR)
TESSERACT_ENABLED=false
TESSERACT_DATA_PATH=./data/tesseract

# Frontend URL (production)
FRONTEND_URL=http://localhost:3000