# OttO Backend Environment Variables
# Copia este archivo a .env y completa los valores

# Database (PostgreSQL)
DATABASE_URL=postgresql://username:password@host:5432/ottodb

# JWT
JWT_SECRET=tu_jwt_secret_aqui_cambialo

# Server
PORT=3001
NODE_ENV=production

# WhatsApp (360dialog)
WHATSAPP_API_KEY=tu_api_key
WHATSAPP_PHONE_ID=tu_phone_id
WHATSAPP_WEBHOOK_VERIFY_TOKEN=tu_verify_token

# AI Service (OpenAI)
OPENAI_API_KEY=tu_api_key_openai
